<?xml version="1.0" encoding="utf-8"?><!--
   The encrypted API key store must never leave the device: its master key
   lives in the device Keystore, so a restored or transferred copy is
   undecryptable.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secret_keys.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secret_keys.xml" />
    </device-transfer>
</data-extraction-rules>
