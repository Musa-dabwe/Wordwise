<?xml version="1.0" encoding="utf-8"?><!--
   The encrypted API key store must never be backed up: its master key lives
   in the device Keystore and does not travel with a backup, so a restored
   copy is undecryptable.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="secret_keys.xml" />
</full-backup-content>
