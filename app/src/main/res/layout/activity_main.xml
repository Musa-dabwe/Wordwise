<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ww_bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/ww_text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textSize="14sp"
                android:textColor="@color/ww_text_secondary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- 1. AI Provider & API Key Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/ww_bg_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_ai_provider"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ww_text_primary" />

                <Spinner
                    android:id="@+id/spinner_provider"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/text_api_key_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_api_key"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ww_text_primary"
                    android:layout_marginTop="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:hintEnabled="false"
                    app:passwordToggleEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_api_key"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:hint="@string/hint_api_key_ollama"
                        android:padding="12dp"
                        android:background="@drawable/edit_text_background" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/text_get_key_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/ww_accent"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/save_api_key_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/save_api_key"
                    android:backgroundTint="@color/ww_accent"
                    android:textColor="@android:color/white" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. Accessibility Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/ww_bg_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_accessibility"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/ww_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_accessibility_helper"
                    android:textSize="13sp"
                    android:textColor="@color/ww_text_secondary"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:id="@+id/serviceStatusTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/status_disabled"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ww_error"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/openAccessibilitySettingsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/open_accessibility_settings"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="@color/ww_accent"
                    app:strokeColor="@color/ww_accent" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. Commands Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ww_bg_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_commands"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/ww_text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/commands_description"
                    android:textSize="13sp"
                    android:textColor="@color/ww_text_secondary"
                    android:layout_marginTop="4dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/ww_bg_inset"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/shortcut_fix_label"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:textColor="@color/ww_accent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/shortcut_fix_desc"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/ww_text_primary" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shortcut_fix_example_before"
                            android:textSize="12sp"
                            android:textColor="@color/ww_text_hint"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shortcut_fix_example_after"
                            android:textSize="12sp"
                            android:textColor="@color/ww_text_secondary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Tips Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tips_header"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/ww_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tips_multilingual"
                        android:textSize="12sp"
                        android:textColor="@color/ww_text_secondary"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tips_structure"
                        android:textSize="12sp"
                        android:textColor="@color/ww_text_secondary"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tips_speed"
                        android:textSize="12sp"
                        android:textColor="@color/ww_text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Info: best use and quota note -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/ww_divider" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/info_best_suited_title"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/ww_text_secondary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/info_best_suited_body"
                    android:textSize="12sp"
                    android:textColor="@color/ww_text_secondary"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/info_quota_note"
                    android:textSize="11sp"
                    android:textColor="@color/ww_text_hint"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
