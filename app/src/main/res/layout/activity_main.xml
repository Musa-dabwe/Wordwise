<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ww_bg_primary"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:fitsSystemWindows="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/ww_text_primary"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textSize="14sp"
                android:textColor="@color/ww_text_secondary"
                android:gravity="center"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card 1: API Key -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ww_bg_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_api_key"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/ww_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_api_key_helper"
                    android:textSize="13sp"
                    android:textColor="@color/ww_text_secondary"
                    android:layout_marginTop="4dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxBackgroundColor="@color/ww_input_bg"
                    app:boxStrokeColor="@color/ww_input_stroke"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1dp"
                    app:hintEnabled="false"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.WordWise.Input">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/apiKeyEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/api_key_hint"
                        android:inputType="textPassword"
                        android:textColorHint="@color/ww_text_hint"
                        android:textColor="@color/ww_text_primary"
                        android:padding="12dp"
                        android:background="@android:color/transparent" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/saveApiKeyButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/save_api_key"
                    android:layout_marginTop="12dp"
                    app:cornerRadius="10dp"
                    android:backgroundTint="@color/ww_accent_button"
                    android:textColor="@color/ww_text_primary"
                    android:textSize="15sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 2: Accessibility Service -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ww_bg_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_accessibility"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/ww_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_accessibility_helper"
                    android:textSize="13sp"
                    android:textColor="@color/ww_text_secondary"
                    android:layout_marginTop="4dp" />

                <Button
                    android:id="@+id/openAccessibilitySettingsButton"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/open_accessibility_settings"
                    android:layout_marginTop="12dp"
                    app:cornerRadius="10dp"
                    app:strokeColor="@color/ww_accent"
                    android:textColor="@color/ww_accent"
                    android:backgroundTint="@android:color/transparent" />

                <TextView
                    android:id="@+id/serviceStatusTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/status_disabled"
                    android:textSize="13sp"
                    android:textColor="@color/ww_status_disabled"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Card 3: Commands -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ww_bg_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_commands"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/ww_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/commands_description"
                    android:textSize="13sp"
                    android:textColor="@color/ww_text_secondary"
                    android:layout_marginTop="4dp" />

                <!-- Inset card: ?fixs -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/ww_bg_inset"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/cmd_fixs_label"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:textColor="@color/ww_accent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/cmd_fixs_desc"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/ww_text_primary" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cmd_fixs_before"
                            android:textSize="12sp"
                            android:textColor="@color/ww_text_hint"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cmd_fixs_after"
                            android:textSize="12sp"
                            android:textColor="@color/ww_text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Inset card: ?fixp -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/ww_bg_inset"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/cmd_fixp_label"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:textColor="@color/ww_accent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/cmd_fixp_desc"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/ww_text_primary" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cmd_fixp_helper"
                            android:textSize="12sp"
                            android:textColor="@color/ww_text_secondary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Inset card: ?fixo -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardBackgroundColor="@color/ww_bg_inset"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/cmd_fixo_label"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:textColor="@color/ww_accent" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/cmd_fixo_desc"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/ww_text_primary" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/cmd_fixo_helper"
                            android:textSize="12sp"
                            android:textColor="@color/ww_text_secondary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Tips Block -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tips_header"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/ww_text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tip_any_app"
                        android:textSize="12sp"
                        android:textColor="@color/ww_text_secondary"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tip_free_tier"
                        android:textSize="12sp"
                        android:textColor="@color/ww_text_secondary"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tip_auto_replace"
                        android:textSize="12sp"
                        android:textColor="@color/ww_text_secondary"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
