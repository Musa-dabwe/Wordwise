<resources>
    <!-- Minimal native theme: the real UI is the pastel htmx frontend in the
         WebView. The window background matches the default Lavender canvas
         tint so launch doesn't flash white. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowBackground">@color/ww_canvas</item>
        <item name="android:statusBarColor">@color/ww_accent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>
</resources>
