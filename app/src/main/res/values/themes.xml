        <item name="colorSurfaceVariant">@color/gh_light_inlay</item>
        <item name="colorOnSurfaceVariant">@color/gh_light_text_secondary</item>
        <item name="colorSurfaceContainer">@color/gh_light_surface</item>
        <item name="colorSurfaceContainerHigh">@color/gh_light_inlay</item>
        <item name="colorSurfaceContainerHighest">@color/gh_light_inlay</item>
        <item name="colorOutline">@color/gh_light_border</item>
        <item name="colorError">@color/gh_light_error</item>
