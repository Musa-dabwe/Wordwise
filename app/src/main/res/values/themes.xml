<resources>
    <!-- ── Shared component styles ─────────────────────────────────── -->
    <style name="Widget.WordWise.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="Widget.WordWise.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.WordWise.SectionLabel" parent="">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <!-- ── Base themes ─────────────────────────────────────────────── -->
    <style name="Base.Theme.WordWise.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="materialButtonStyle">@style/Widget.WordWise.Button</item>
    </style>

    <style name="Base.Theme.WordWise.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:forceDarkAllowed">false</item>
        <item name="materialButtonStyle">@style/Widget.WordWise.Button</item>
    </style>

    <!-- ── GitHub Dark ─────────────────────────────────────────────── -->
    <style name="Theme.WordWise.GithubDark" parent="Base.Theme.WordWise.Dark">
        <item name="android:colorBackground">@color/gh_dark_bg</item>
        <item name="android:windowBackground">@color/gh_dark_bg</item>
        <item name="colorPrimary">@color/gh_dark_primary</item>
        <item name="colorOnPrimary">@color/gh_dark_on_primary</item>
        <item name="colorSurface">@color/gh_dark_surface</item>
        <item name="colorOnSurface">@color/gh_dark_text</item>
        <item name="colorOnBackground">@color/gh_dark_text</item>
        <item name="colorSurfaceVariant">@color/gh_dark_inlay</item>
        <item name="colorOnSurfaceVariant">@color/gh_dark_text_secondary</item>
        <item name="colorSurfaceContainer">@color/gh_dark_surface</item>
        <item name="colorSurfaceContainerHigh">@color/gh_dark_inlay</item>
        <item name="colorSurfaceContainerHighest">@color/gh_dark_inlay</item>
        <item name="colorOutline">@color/gh_dark_border</item>
        <item name="colorError">@color/gh_dark_error</item>
        <item name="wwSuccess">@color/gh_dark_success</item>
    </style>

    <!-- ── GitHub Light ────────────────────────────────────────────── -->
    <style name="Theme.WordWise.GithubLight" parent="Base.Theme.WordWise.Light">
